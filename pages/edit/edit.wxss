/**pages/edit/edit.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.section-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.section-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.edit-hint {
  font-size: 26rpx;
  color: #07c160;
}

.add-btn {
  font-size: 26rpx;
  color: #07c160;
  padding: 8rpx 20rpx;
  border: 1rpx solid #07c160;
  border-radius: 24rpx;
}

.section-body {
  padding: 20rpx 30rpx 30rpx;
}

.section-body.hint {
  padding: 20rpx 30rpx;
}

.hint-text {
  font-size: 26rpx;
  color: #ccc;
}

.info-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.info-row {
  display: flex;
  gap: 20rpx;
  font-size: 26rpx;
  color: #666;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.list-item:last-child {
  border-bottom: none;
}

.item-content {
  flex: 1;
}

.item-title {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}

.item-sub {
  font-size: 24rpx;
  color: #999;
}

.item-delete {
  font-size: 24rpx;
  color: #ee0a24;
  padding: 8rpx 16rpx;
}

/* 模板入口 */
.template-entry {
  background: linear-gradient(135deg, #fff, #f8f9fa);
}

.template-hint {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.template-color-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
}

.template-name-hint {
  font-size: 24rpx;
  color: #666;
}