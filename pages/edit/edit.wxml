<!--pages/edit/edit.wxml-->
<scroll-view class="scrollarea" scroll-y type="list">
  <view class="container">

    <!-- 头像区域 -->
    <view class="avatar-area" bindtap="onChooseAvatar">
      <image wx:if="{{basicInfo.avatar}}" class="avatar-img" src="{{basicInfo.avatar}}" mode="aspectFill" />
      <view wx:else class="avatar-placeholder">
        <text class="avatar-plus">+</text>
        <text class="avatar-text">添加头像</text>
      </view>
    </view>

    <!-- 基础信息模块 -->
    <view class="module">
      <view class="module-header" bindtap="editBasicInfo">
        <text class="module-title">基础信息</text>
        <text class="module-arrow">></text>
      </view>
      <view class="module-body" wx:if="{{basicInfo.name}}">
        <view class="info-row">
          <text wx:if="{{basicInfo.name}}">{{basicInfo.name}}</text>
          <text wx:if="{{basicInfo.gender}}">{{basicInfo.gender}}</text>
          <text wx:if="{{basicInfo.age}}">{{basicInfo.age}}岁</text>
          <text wx:if="{{basicInfo.phone}}">{{basicInfo.phone}}</text>
          <text wx:if="{{basicInfo.email}}">{{basicInfo.email}}</text>
        </view>
        <view class="info-row">
          <text wx:if="{{basicInfo.city}}">{{basicInfo.city}}</text>
          <text wx:if="{{basicInfo.education}}">{{basicInfo.education}}</text>
          <text wx:if="{{basicInfo.school}}">{{basicInfo.school}}</text>
          <text wx:if="{{basicInfo.major}}">{{basicInfo.major}}</text>
        </view>
      </view>
      <view class="module-body hint" wx:else>
        <text class="hint-text">点击填写基础信息</text>
      </view>
    </view>

    <!-- 求职意向模块 -->
    <view class="module">
      <view class="module-header" bindtap="editJobIntention">
        <text class="module-title">求职意向</text>
        <text class="module-arrow">></text>
      </view>
      <view class="module-body" wx:if="{{jobIntention.position || jobIntention.location || jobIntention.salary}}">
        <view class="info-row">
          <text wx:if="{{jobIntention.position}}">{{jobIntention.position}}</text>
          <text wx:if="{{jobIntention.location}}">{{jobIntention.location}}</text>
          <text wx:if="{{jobIntention.salary}}">{{jobIntention.salary}}</text>
        </view>
      </view>
      <view class="module-body hint" wx:else>
        <text class="hint-text">列出期望职位、地点、薪资等</text>
      </view>
    </view>

    <!-- 自我评价模块 -->
    <view class="module">
      <view class="module-header" bindtap="editSelfEvaluation">
        <text class="module-title">自我评价</text>
        <text class="module-arrow">></text>
      </view>
      <view class="module-body" wx:if="{{selfEvaluation}}">
        <text class="eval-text">{{selfEvaluation}}</text>
      </view>
      <view class="module-body hint" wx:else>
        <text class="hint-text">总结优势，突出亮点</text>
      </view>
    </view>

    <!-- 已添加的模块 -->
    <view class="module" wx:for="{{activeModules}}" wx:key="key">
      <view class="module-header">
        <text class="module-title">{{item.icon}} {{item.title}}</text>
        <view class="add-btn" catchtap="addModuleItem" data-key="{{item.key}}">+ 添加</view>
      </view>
      <view class="module-body">
        <view class="list-item" wx:for="{{item.items}}" wx:key="id" wx:for-item="sub" wx:for-index="idx">
          <view class="item-content" bindtap="editModuleItem" data-key="{{item.key}}" data-index="{{idx}}">
            <text class="item-title">{{sub.school || sub.company || sub.name || sub.title}}</text>
            <text class="item-sub" wx:if="{{sub.major || sub.position || sub.role}}">{{sub.major || sub.position || sub.role}}</text>
          </view>
          <view class="item-delete" catchtap="deleteModuleItem" data-key="{{item.key}}" data-index="{{idx}}">删除</view>
        </view>
      </view>
    </view>

    <!-- 添加模块网格 -->
    <view class="add-section">
      <view class="add-grid">
        <view class="add-grid-item" wx:for="{{moduleConfig}}" wx:key="key" bindtap="addModuleItem" data-key="{{item.key}}">
          <view class="add-icon">{{item.icon}}</view>
          <text class="add-label">{{item.title}}</text>
        </view>
      </view>
    </view>

  </view>
</scroll-view>

<!-- 底部操作栏 -->
<view class="bottom-bar">
  <button class="bottom-btn" bindtap="goToTemplates">选择模板</button>
</view>
