/**pages/templates/templates.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.container {
  padding: 20rpx 24rpx;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.tpl-card {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  border: 3rpx solid transparent;
}

.tpl-card.active {
  border-color: #007AFF;
}

.card-preview {
  height: 320rpx;
  padding: 24rpx;
  display: flex;
  gap: 16rpx;
}

.preview-bar {
  width: 80rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.preview-lines {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding-top: 16rpx;
}

.p-line {
  height: 12rpx;
  border-radius: 6rpx;
}

.card-info {
  padding: 20rpx 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.card-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.card-badge {
  font-size: 20rpx;
  color: #007AFF;
  background: #007AFF15;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.card-desc {
  font-size: 22rpx;
  color: #999;
  line-height: 1.4;
}

.bottom-bar {
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.preview-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #007AFF;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
}
