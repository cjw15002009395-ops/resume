/**components/section/section.wxss**/
.section-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.section-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.section-count {
  font-size: 24rpx;
  color: #999;
  margin-right: 20rpx;
}

.add-btn {
  font-size: 26rpx;
  color: #07c160;
  padding: 8rpx 20rpx;
  border: 1rpx solid #07c160;
  border-radius: 24rpx;
}

.section-body {
  padding: 10rpx 30rpx 30rpx;
}