.template-elegant {
  background: #f0f4f8;
}

.banner {
  background: linear-gradient(135deg, #1a73e8, #4a9af5);
  padding: 50rpx 40rpx 40rpx;
  color: #fff;
}

.banner-content {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-bottom: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  flex-shrink: 0;
}

.banner-info {
  flex: 1;
}

.name {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 10rpx;
}

.contact-row {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.summary {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.7;
}

.body {
  padding: 20rpx 30rpx;
}

.section {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a73e8;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #1a73e8;
}

.section-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-item:last-child {
  border-bottom: none;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.item-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.item-date {
  font-size: 22rpx;
  color: #999;
}

.item-sub {
  font-size: 26rpx;
  color: #666;
}

.item-desc {
  font-size: 26rpx;
  color: #888;
  line-height: 1.6;
  margin-top: 8rpx;
}

.skill-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.skill-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.skill-name {
  width: 140rpx;
  font-size: 26rpx;
  color: #333;
}

.skill-bar {
  flex: 1;
  height: 14rpx;
  background: #e8f0fe;
  border-radius: 7rpx;
  overflow: hidden;
}

.skill-fill {
  height: 100%;
  background: #1a73e8;
  border-radius: 7rpx;
}

.skill-val {
  font-size: 22rpx;
  color: #999;
  width: 60rpx;
  text-align: right;
}
