<!-- 优雅蓝调模板 -->
<view class="template-elegant">
  <!-- 蓝色头部横幅 -->
  <view class="banner">
    <view class="banner-content">
      <image wx:if="{{resumeData.basicInfo.avatar}}" class="avatar" src="{{resumeData.basicInfo.avatar}}" mode="aspectFill" />
      <view class="banner-info">
        <text class="name">{{resumeData.basicInfo.name}}</text>
        <view class="contact-row" wx:if="{{resumeData.basicInfo.phone || resumeData.basicInfo.email}}">
          <text wx:if="{{resumeData.basicInfo.phone}}">{{resumeData.basicInfo.phone}}</text>
          <text wx:if="{{resumeData.basicInfo.email}}">{{resumeData.basicInfo.email}}</text>
        </view>
      </view>
    </view>
    <view class="summary" wx:if="{{resumeData.basicInfo.summary}}">
      {{resumeData.basicInfo.summary}}
    </view>
  </view>

  <!-- 正文区域 -->
  <view class="body">
    <!-- 教育经历 -->
    <view class="section" wx:if="{{resumeData.education.length > 0}}">
      <view class="section-title">教育经历</view>
      <view class="section-item" wx:for="{{resumeData.education}}" wx:key="id">
        <view class="item-header">
          <text class="item-title">{{item.school}}</text>
          <text class="item-date">{{item.startDate}} - {{item.endDate}}</text>
        </view>
        <text class="item-sub">{{item.major}} · {{item.degree}}</text>
      </view>
    </view>

    <!-- 工作经历 -->
    <view class="section" wx:if="{{resumeData.workExperience.length > 0}}">
      <view class="section-title">工作经历</view>
      <view class="section-item" wx:for="{{resumeData.workExperience}}" wx:key="id">
        <view class="item-header">
          <text class="item-title">{{item.company}}</text>
          <text class="item-date">{{item.startDate}} - {{item.endDate}}</text>
        </view>
        <text class="item-sub">{{item.position}}</text>
        <text class="item-desc" wx:if="{{item.description}}">{{item.description}}</text>
      </view>
    </view>

    <!-- 专业技能 -->
    <view class="section" wx:if="{{resumeData.skills.length > 0}}">
      <view class="section-title">专业技能</view>
      <view class="skill-list">
        <view class="skill-item" wx:for="{{resumeData.skills}}" wx:key="id">
          <text class="skill-name">{{item.name}}</text>
          <view class="skill-bar">
            <view class="skill-fill" style="width: {{item.level}}%"></view>
          </view>
          <text class="skill-val">{{item.level}}%</text>
        </view>
      </view>
    </view>

    <!-- 项目经验 -->
    <view class="section" wx:if="{{resumeData.projects.length > 0}}">
      <view class="section-title">项目经验</view>
      <view class="section-item" wx:for="{{resumeData.projects}}" wx:key="id">
        <view class="item-header">
          <text class="item-title">{{item.name}}</text>
          <text class="item-date">{{item.startDate}} - {{item.endDate}}</text>
        </view>
        <text class="item-sub" wx:if="{{item.role}}">{{item.role}}</text>
        <text class="item-desc" wx:if="{{item.description}}">{{item.description}}</text>
      </view>
    </view>
  </view>
</view>
