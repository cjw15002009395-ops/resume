.template-creative {
  position: relative;
}

/* 左侧彩色装饰条 */
.template-creative::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: linear-gradient(to bottom, #ff6b6b, #4ecdc4, #ffe66d, #ff6b6b);
  border-radius: 0 4rpx 4rpx 0;
}

.header {
  background: #fff;
  padding: 40rpx 30rpx 30rpx 40rpx;
  margin-bottom: 20rpx;
}

.accent-bar {
  height: 6rpx;
  background: linear-gradient(90deg, #ff6b6b, #4ecdc4, #ffe66d);
  border-radius: 3rpx;
  margin-bottom: 30rpx;
}

.header-content {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.header-info {
  flex: 1;
}

.name {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.contact-row {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  font-size: 24rpx;
  color: #666;
}

.summary {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  padding-top: 16rpx;
  border-top: 1rpx dashed #e0e0e0;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx 30rpx 30rpx 40rpx;
  margin: 0 20rpx 20rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.d1 { background: #ff6b6b; }
.d2 { background: #4ecdc4; }
.d3 { background: #ffe66d; }
.d4 { background: #a78bfa; }

.section-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.section-item:last-child {
  border-bottom: none;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.item-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.item-date {
  font-size: 22rpx;
  color: #999;
}

.item-sub {
  font-size: 26rpx;
  color: #666;
}

.item-desc {
  font-size: 26rpx;
  color: #888;
  line-height: 1.6;
  margin-top: 8rpx;
}

.skill-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.skill-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.skill-name {
  width: 140rpx;
  font-size: 26rpx;
  color: #333;
}

.skill-bar {
  flex: 1;
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.skill-fill {
  height: 100%;
  background: linear-gradient(90deg, #ff6b6b, #ffe66d);
  border-radius: 8rpx;
}
