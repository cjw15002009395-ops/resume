/**components/empty-state/empty-state.wxss**/
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.empty-msg {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.empty-btn {
  font-size: 26rpx;
  color: #07c160;
  background: none;
  border: 1rpx solid #07c160;
  border-radius: 24rpx;
  padding: 8rpx 30rpx;
  line-height: 1.5;
}