.template-minimal {
  padding: 40rpx 40rpx;
}

.header {
  padding-bottom: 36rpx;
  border-bottom: 1rpx solid #e0e0e0;
  margin-bottom: 36rpx;
}

.header-top {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.name {
  font-size: 44rpx;
  font-weight: bold;
  color: #222;
}

.contact-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
  color: #888;
  margin-bottom: 20rpx;
}

.sep {
  color: #ddd;
}

.summary {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
}

.section {
  padding-bottom: 36rpx;
  margin-bottom: 36rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.section:last-child {
  border-bottom: none;
  margin-bottom: 0;
}

.section-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #222;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  margin-bottom: 24rpx;
}

.section-item {
  margin-bottom: 24rpx;
}

.section-item:last-child {
  margin-bottom: 0;
}

.item-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 6rpx;
}

.item-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.item-date {
  font-size: 22rpx;
  color: #aaa;
}

.item-sub {
  font-size: 26rpx;
  color: #666;
}

.item-desc {
  font-size: 26rpx;
  color: #888;
  line-height: 1.7;
  margin-top: 8rpx;
}

.skill-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.skill-text {
  font-size: 26rpx;
  color: #555;
  background: #f7f7f7;
  padding: 8rpx 20rpx;
  border-radius: 6rpx;
}
